# ───────────────────────────────────────────────────────────────
# CPL — environment variables
# ───────────────────────────────────────────────────────────────
# Copy this file to .env.local for local dev, OR set these in
# Vercel project settings → Environment Variables for production.
# ───────────────────────────────────────────────────────────────

# ─── REQUIRED ───────────────────────────────────────────────────

# Resend API key. Get one at https://resend.com/api-keys
# Free tier: 3,000 emails/month, 100 emails/day.
RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxxxxxxxx

# Secret used to sign HMAC tokens for confirmation & unsubscribe links.
# Must be 32+ characters. Generate with:  openssl rand -hex 32
CPL_TOKEN_SECRET=replace-with-random-64-char-hex-string-from-openssl

# ─── OPTIONAL (sensible defaults shown) ────────────────────────

# Sender address shown in emails.
# Default uses Resend's onboarding sandbox (no domain verification needed).
# Once you verify a domain in Resend, switch to e.g. 'CPL <hello@clinicalperformancelab.com>'
CPL_FROM_ADDRESS=CPL <onboarding@resend.dev>

# Base URL for confirmation / unsubscribe links and PDF downloads.
# Vercel sets this automatically per deployment as VERCEL_URL, but we
# want a stable URL across redeploys.
CPL_BASE_URL=https://clinicalperformancelab.vercel.app

# Optional secret for manually triggering the drip cron from a browser.
# If unset, only Vercel's internal cron header is accepted.
# CRON_SECRET=optional-secret-for-manual-cron-triggering

# ─── VERCEL KV (auto-populated when you add KV in Vercel dashboard) ─
# These are set automatically by Vercel when you provision a KV store.
# You don't need to set them manually if using Vercel KV via the dashboard.
# KV_URL=
# KV_REST_API_URL=
# KV_REST_API_TOKEN=
# KV_REST_API_READ_ONLY_TOKEN=
